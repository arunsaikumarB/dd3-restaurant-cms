# Supabase — use VITE_ prefix (required for Vite) or NEXT_PUBLIC_ (compatible alias)

# Project URL — Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — safe for browser
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never commit real values. Never use in React.
SUPABASE_SERVICE_ROLE_KEY=
