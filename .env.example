# =============================================================================
# Desi Dhamaka — environment variables
# Copy to .env.local for local development.
# Set in Netlify → Site configuration → Environment variables for deploys.
# =============================================================================

# Public site URL (no trailing slash)
# Demo/staging:  https://your-demo-name.netlify.app
# Production:    https://desidhamakanj.net/lawrenceville
VITE_SITE_URL=

# Supabase — Project URL (Settings → API)
VITE_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Supabase — anon public key (safe for browser)
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never commit. Never use in React or Netlify.
SUPABASE_SERVICE_ROLE_KEY=

# Serper.dev API key — SERVER ONLY (Netlify Functions).
# Used by netlify/functions/google-reviews-sync.mts to pull Google Maps
# reviews per location (see src/config/locations.ts googlePlaceId). Free plan:
# 100 searches/month, no card required. Never expose to the browser.
SERPER_API_KEY=

# Google Analytics 4 (Data API) — SERVER ONLY (Netlify Functions).
# Used by netlify/functions/analytics-ga4.mts. Never expose to the browser.
# GA4_PRIVATE_KEY: paste as ONE line with \n between PEM lines (not literal line breaks).
# Example: -----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# SMTP — SERVER ONLY (Netlify Functions). Used by
# netlify/functions/submit-enquiry.mts (via nodemailer) to email
# contact/catering enquiries. Example (IONOS): host smtp.ionos.com,
# port 465 (implicit TLS) or 587 (STARTTLS).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# "From" address — defaults to SMTP_USER if left blank.
SMTP_FROM=

# TEMPORARY shared test inbox for all 6 enquiry forms (3 locations x
# contact/catering). Replace with real per-form recipients in
# src/config/enquiryRecipients.ts when ready.
ENQUIRY_NOTIFY_EMAIL=
