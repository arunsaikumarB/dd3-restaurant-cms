# =============================================================================
# Desi Dhamaka — environment variables
# Copy to .env.local for local development.
# Set in Netlify → Site configuration → Environment variables for deploys.
# =============================================================================

# Public site URL (no trailing slash)
# Demo/staging:  https://your-demo-name.netlify.app
# Production:    https://desidhamakanj.net/lawrenceville
VITE_SITE_URL=

# Supabase — Project URL (Settings → API)
VITE_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Supabase — anon public key (safe for browser)
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never commit. Never use in React or Netlify.
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics 4 (Data API) — SERVER ONLY (Netlify Functions).
# Used by netlify/functions/analytics-ga4.mts. Never expose to the browser.
# GA4_PRIVATE_KEY: paste as ONE line with \n between PEM lines (not literal line breaks).
# Example: -----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# Cheffy AI provider (client service layer — no API keys in the browser).
# gemini | openai | claude | mock
VITE_AI_PROVIDER=gemini

# Cheffy AI — SERVER ONLY (Netlify Function: ai-concierge).
# Gemini is the default provider for demo. Keys must never be exposed to React.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_STREAMING=true
CHEFFY_PROMPT_VERSION=1

# Optional OpenAI provider (AI_PROVIDER=openai, VITE_AI_PROVIDER=openai).
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
OPENAI_MAX_OUTPUT_TOKENS=1024

# Optional Claude provider (AI_PROVIDER=claude).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
